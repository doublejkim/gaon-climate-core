APP_PORT=8080
SPRING_PROFILES_ACTIVE=prod
APP_ADMIN_TOKEN=change-this-admin-token

# [CORS] 이 API를 호출하는 웹 프론트엔드의 오리진(scheme+host[+port]).
#  - 브라우저 주소창 기준의 오리진을 그대로 적는다. 예) https://your-web-domain
#  - 여러 개면 콤마로 구분. 예) https://your-web-domain,https://your-admin-domain
#  - allowCredentials(true) 라 와일드카드('*')는 불가. 정확한 오리진을 명시해야 한다.
APP_CORS_ALLOWED_ORIGINS=https://your-web-domain

# [Traefik] 이 API가 노출될 실제 도메인. Traefik Host() 라우팅 규칙에 사용된다.
#  - 예) api.your-domain (API 서브도메인)
API_DOMAIN=api.your-domain

SPRING_DATASOURCE_URL=jdbc:mariadb://your-mariadb-host:3306/gaon_climate
SPRING_DATASOURCE_USERNAME=gaon
SPRING_DATASOURCE_PASSWORD=change-db-password

APP_CLIMATE_HISTORY_WINDOW_SECONDS=3600
APP_CLIMATE_HISTORY_BUCKET_SECONDS=600
TZ=Asia/Seoul
